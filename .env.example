# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sso_exposure_scanner
POSTGRES_SSL=disable

# Token encryption for OAuth credentials at rest
TOKEN_ENCRYPTION_KEY=replace-with-a-32-char-secret

# Vercel OAuth
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=

# Netlify OAuth
NETLIFY_CLIENT_ID=
NETLIFY_CLIENT_SECRET=

# Lemon Squeezy checkout and webhook
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
